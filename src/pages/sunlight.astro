---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="sunlight | human nature health"
  description="natural light, circadian rhythm, and energy."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">sunlight</p>
      <h1>light tells your body how to live the day.</h1>
      <p class="lead">
        natural light helps regulate energy, mood, sleep timing, and overall rhythm.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="content-block">
        <h2>why it matters</h2>
        <p>
          sunlight sets your internal clock. it influences hormones, alertness,
          and sleep quality later in the day.
        </p>
      </div>

      <div class="content-block">
        <h2>what goes wrong</h2>
        <p>
          too much time indoors, artificial light at night, and lack of morning light
          confuse the body’s natural rhythm.
        </p>
      </div>

      <div class="content-block">
        <h2>core principles</h2>
        <div class="content-list">
          <p>get sunlight early in the day</p>
          <p>spend time outside regularly</p>
          <p>avoid bright artificial light at night</p>
          <p>let light follow a natural pattern</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section accent-section">
    <div class="container narrow">
      <h2>simple light rhythm</h2>

      <div class="content-block">
        <h3>morning</h3>
        <p>go outside and let natural light hit your eyes.</p>
      </div>

      <div class="content-block">
        <h3>day</h3>
        <p>stay exposed to natural light as much as possible.</p>
      </div>

      <div class="content-block">
        <h3>night</h3>
        <p>reduce artificial light so the body can prepare for sleep.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="quote-block">
        <p>light is one of the strongest signals your body responds to.</p>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">checklist</p>
          <span class="panel-stamp">light</span>
        </div>
        <h2>simple sunlight checklist</h2>
        <div class="content-list">
          <p>get outside within 30–60 min of waking</p>
          <p>no sunglasses during early light exposure</p>
          <p>spend at least 20–45 min outside daily</p>
          <p>limit bright screens late at night</p>
          <p>dim indoor lighting after sunset</p>
        </div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container narrow">
      <div class="two-panel-grid">
        <a href="/sleep" class="y2k-panel feature-card">
          <p class="panel-kicker">previous</p>
          <h3>sleep</h3>
          <p>return to the foundation of recovery and rest.</p>
        </a>

        <a href="/movement" class="y2k-panel feature-card">
          <p class="panel-kicker">next</p>
          <h3>movement</h3>
          <p>continue into using the body and building strength.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>