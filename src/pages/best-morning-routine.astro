---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="best morning routine for natural energy"
  description="a simple, natural morning routine for energy, clarity, and health."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">guide</p>
      <h1>the best morning routine for natural energy</h1>
      <p class="lead">
        most people don’t need a complicated routine. they need a few key actions done consistently.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="content-block">
        <h2>the simple structure</h2>
        <div class="content-list">
          <p>wake at a consistent time</p>
          <p>get sunlight within 30–60 minutes</p>
          <p>move your body (walk or light exercise)</p>
          <p>eat a stable first meal</p>
          <p>avoid instant phone stimulation</p>
        </div>
      </div>

      <div class="content-block">
        <h2>why this works</h2>
        <p>
          this routine aligns your body with natural rhythms. light, movement, and stable energy
          early in the day influence everything that follows.
        </p>
      </div>
    </div>
  </section>

  <section class="section accent-section">
    <div class="container narrow">
      <h2>common mistakes</h2>

      <div class="content-block">
        <p>waking up and going straight to your phone</p>
        <p>no sunlight exposure</p>
        <p>skipping movement completely</p>
        <p>unstable caffeine-heavy starts</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">checklist</p>
          <span class="panel-stamp">morning</span>
        </div>
        <h2>simple morning checklist</h2>
        <div class="content-list">
          <p>wake at the same time daily</p>
          <p>get outside within 30–60 minutes</p>
          <p>move for 5–20 minutes</p>
          <p>delay phone use</p>
          <p>eat a stable first meal</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">related</p>
          <span class="panel-stamp">next</span>
        </div>
        <h2>go deeper</h2>
        <div class="content-list">
          <p><a href="/best-sleep-routine">build a consistent sleep routine</a></p>
          <p><a href="/how-to-fix-sleep">fix common sleep problems</a></p>
          <p><a href="/start-here">follow the full baseline system</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">free guide</p>
          <span class="panel-stamp">system</span>
        </div>
        <h2>build your full daily baseline</h2>

        <form class="hero-actions" action="/start-here" method="GET">
          <input
            class="email-input"
            type="email"
            name="email"
            placeholder="your email"
            required
          />
          <button class="button primary-cta" type="submit">
            get the guide
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="two-panel-grid">
        <a href="/start-here" class="y2k-panel feature-card">
          <p class="panel-kicker">previous</p>
          <h3>start here</h3>
          <p>begin with the core basics and simple pathway.</p>
        </a>

        <a href="/best-sleep-routine" class="y2k-panel feature-card">
          <p class="panel-kicker">next</p>
          <h3>sleep routine</h3>
          <p>move into deeper rest and a consistent night rhythm.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>