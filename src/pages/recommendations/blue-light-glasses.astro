---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="best blue light blocking glasses"
  description="simple, effective blue light glasses to improve sleep and reduce night stimulation."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">recommendation</p>
      <h1>blue light blocking glasses for better sleep</h1>
      <p class="lead">
        if you use screens at night, this is one of the simplest tools to reduce stimulation and support better sleep.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="content-block">
        <h2>why this matters</h2>
        <p>
          artificial light at night can disrupt your natural sleep rhythm. blue light blocking glasses help reduce that effect,
          making it easier to wind down and fall asleep.
        </p>
      </div>

      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">recommended</p>
          <span class="panel-stamp">simple tool</span>
        </div>
        <h2>blue light blocking glasses</h2>

        <div class="content-list">
          <p>blocks stimulating blue light</p>
          <p>supports natural melatonin production</p>
          <p>easy to use daily</p>
        </div>

        <button class="button primary-cta" disabled>available soon</button>
        <p class="panel-kicker" style="margin-top: 0.5rem;">curating a clean, effective option</p>
      </div>

      <div class="content-block">
        <h2>how to use</h2>
        <div class="content-list">
          <p>wear 60–90 minutes before bed</p>
          <p>use with dim lighting</p>
          <p>combine with reduced screen time if possible</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">related</p>
          <span class="panel-stamp">sleep</span>
        </div>
        <h2>go deeper</h2>
        <div class="content-list">
          <p><a href="/how-to-fix-sleep">fix your sleep</a></p>
          <p><a href="/best-sleep-routine">build a sleep routine</a></p>
          <p><a href="/why-you-feel-tired-all-the-time">understand low energy</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
