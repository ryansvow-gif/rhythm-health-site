

---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="magnesium for sleep and recovery"
  description="how magnesium supports sleep, relaxation, and recovery naturally."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">recommendation</p>
      <h1>magnesium for better sleep and recovery</h1>
      <p class="lead">
        magnesium is one of the simplest and most effective ways to support relaxation, sleep quality, and nervous system balance.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="content-block">
        <h2>why this matters</h2>
        <p>
          many people are low in magnesium. this can lead to poor sleep, muscle tension, stress,
          and a harder time winding down at night.
        </p>
      </div>

      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">recommended</p>
          <span class="panel-stamp">sleep tool</span>
        </div>
        <h2>magnesium (glycinate)</h2>

        <div class="content-list">
          <p>supports deeper sleep</p>
          <p>helps calm the nervous system</p>
          <p>can reduce tension and restlessness</p>
        </div>

        <button class="button primary-cta" disabled>available soon</button>
        <p class="panel-kicker" style="margin-top: 0.5rem;">curating a clean, effective option</p>
      </div>

      <div class="content-block">
        <h2>how to use</h2>
        <div class="content-list">
          <p>take in the evening</p>
          <p>combine with good sleep habits</p>
          <p>stay consistent daily</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">related</p>
          <span class="panel-stamp">sleep</span>
        </div>
        <h2>go deeper</h2>
        <div class="content-list">
          <p><a href="/how-to-fix-sleep">fix your sleep</a></p>
          <p><a href="/best-sleep-routine">build a sleep routine</a></p>
          <p><a href="/why-you-feel-tired-all-the-time">understand low energy</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>