

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="why you have low motivation (and how to fix it)"
  description="understand low motivation and how to fix it naturally through energy, focus, and rhythm."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">guide</p>
      <h1>low motivation? here’s what’s actually causing it</h1>
      <p class="lead">
        if you feel stuck, unmotivated, or unable to start, it’s usually not laziness — it’s your system being out of balance.
      </p>
      <p class="lead">
        fix the system, and motivation starts to return naturally.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="content-block">
        <h2>common causes</h2>
        <div class="content-list">
          <p>low energy and poor sleep</p>
          <p>overstimulation and dopamine overload</p>
          <p>lack of direction or structure</p>
          <p>mental fatigue</p>
          <p>no clear starting point</p>
        </div>
      </div>

      <div class="content-block">
        <h2>what’s actually happening</h2>
        <p>
          motivation is a byproduct. when your body has energy, your mind has clarity, and your environment is simple,
          action becomes natural.
        </p>
      </div>
    </div>
  </section>

  <section class="section accent-section">
    <div class="container narrow">
      <h2>quick reset</h2>

      <div class="content-block">
        <p>fix sleep first</p>
        <p>reduce overstimulation</p>
        <p>start extremely small</p>
        <p>focus on consistency, not intensity</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">checklist</p>
          <span class="panel-stamp">motivation</span>
        </div>
        <h2>simple motivation checklist</h2>
        <div class="content-list">
          <p>consistent sleep</p>
          <p>reduce distractions</p>
          <p>clear next action</p>
          <p>small daily wins</p>
          <p>repeat daily</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">related</p>
          <span class="panel-stamp">flow</span>
        </div>
        <h2>go deeper</h2>
        <div class="content-list">
          <p><a href="/why-you-feel-tired-all-the-time">fix your energy first</a></p>
          <p><a href="/cant-focus">rebuild focus</a></p>
          <p><a href="/start-here">follow the full baseline system</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">free guide</p>
          <span class="panel-stamp">system</span>
        </div>
        <h2>build your full baseline</h2>

        <form class="hero-actions" action="/start-here" method="GET">
          <input
            class="email-input"
            type="email"
            name="email"
            placeholder="your email"
            required
          />
          <button class="button primary-cta" type="submit">
            get the guide
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="two-panel-grid">
        <a href="/cant-focus" class="y2k-panel feature-card">
          <p class="panel-kicker">previous</p>
          <h3>can’t focus?</h3>
          <p>build attention before motivation.</p>
        </a>

        <a href="/start-here" class="y2k-panel feature-card">
          <p class="panel-kicker">next</p>
          <h3>start here</h3>
          <p>return to the full system.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>