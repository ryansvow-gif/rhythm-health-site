---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="human nature health"
  description="natural health guidance centered on sleep, sunlight, movement, food, nervous system balance, and clarity."
>
  <section class="section home-shell">
    <div class="container home-grid">
      <div class="main-column">

        <!-- HERO (SIMPLIFIED ENTRY LAYER) -->
        <section class="y2k-panel hero-panel hero-panel-large">
          <p class="panel-kicker">human nature health</p>
          <h1>health begins when life is aligned with human design.</h1>
          <p class="lead">
            identify your state and enter.
          </p>
          <p class="lead">
            most modern health issues come from disrupted rhythm in sleep, light, movement, food, and overstimulation.
          </p>
          <p class="lead">
            this system helps you identify and correct it quickly.
          </p>

          <div class="hero-actions">
            <a class="button" href="/start-here">enter system</a>
          </div>
        </section>

        <!-- ENTRY POINTS (ONLY 3 PATHS) -->
        <section class="section-header-strip">
          <p class="panel-kicker">start here</p>
          <h2>what are you dealing with?</h2>
          <p class="lead">pick one and begin</p>
        </section>

        <section class="three-panel-grid">
          <a href="/why-you-feel-tired-all-the-time" class="info-card y2k-panel topic-card">
            <span class="panel-stamp">popular</span>
            <p class="card-label">problem</p>
            <h3>always tired?</h3>
            <p>fix low energy through sleep, light, and daily rhythm.</p>
          </a>

          <a href="/cant-focus" class="info-card y2k-panel topic-card">
            <span class="panel-stamp">popular</span>
            <p class="card-label">problem</p>
            <h3>can’t focus?</h3>
            <p>restore attention by reducing overstimulation and stabilizing rhythm.</p>
          </a>

          <a href="/low-motivation" class="info-card y2k-panel topic-card">
            <p class="card-label">problem</p>
            <h3>low motivation?</h3>
            <p>rebuild drive by fixing energy, clarity, and structure.</p>
          </a>
        </section>

      </div>
    </div>
  </section>
</BaseLayout>