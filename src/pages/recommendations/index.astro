---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="recommended tools"
  description="simple, effective tools to support sleep, focus, and overall health."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">recommendations</p>
      <h1>simple tools that actually help</h1>
      <p class="lead">
        these are optional tools that support better sleep, focus, and daily rhythm.
        nothing excessive — just what actually works.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">sleep</p>
          <span class="panel-stamp">tools</span>
        </div>
        <h2>sleep support</h2>

        <div class="content-list">
          <p><a href="/recommendations/blue-light-glasses">blue light blocking glasses</a></p>
          <p><a href="/recommendations/magnesium">magnesium (glycinate)</a></p>
        </div>
      </div>

      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">focus</p>
          <span class="panel-stamp">tools</span>
        </div>
        <h2>focus support</h2>

        <div class="content-list">
          <p><a href="/recommendations/focus-timer">focus timer</a></p>
          <p><a href="/recommendations/minimal-notebook">minimal notebook</a></p>
        </div>
      </div>

      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">system</p>
          <span class="panel-stamp">tools</span>
        </div>
        <h2>daily system support</h2>

        <div class="content-list">
          <p><a href="/recommendations/morning-light-lamp">morning light lamp</a></p>
          <p><a href="/recommendations/grounding-mat">grounding mat</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>