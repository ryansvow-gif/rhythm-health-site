---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="best sleep routine for deep rest"
  description="a simple, natural sleep routine for deeper rest and recovery."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">guide</p>
      <h1>the best sleep routine for deep rest</h1>
      <p class="lead">
        most sleep problems come from rhythm disruption, not complexity. a simple structure fixes most of it.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="content-block">
        <h2>the simple structure</h2>
        <div class="content-list">
          <p>sleep and wake at the same time daily</p>
          <p>dim lights 60–90 minutes before bed</p>
          <p>reduce screens late at night</p>
          <p>keep your room cool and dark</p>
          <p>get sunlight early the next day</p>
        </div>
      </div>

      <div class="content-block">
        <h2>why this works</h2>
        <p>
          your body follows patterns. when light, timing, and stimulation are consistent,
          sleep becomes automatic instead of forced.
        </p>
      </div>
    </div>
  </section>

  <section class="section accent-section">
    <div class="container narrow">
      <h2>common mistakes</h2>

      <div class="content-block">
        <p>staying up at inconsistent times</p>
        <p>bright lights and screens late at night</p>
        <p>too much stimulation before bed</p>
        <p>no morning light exposure</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">checklist</p>
          <span class="panel-stamp">sleep</span>
        </div>
        <h2>simple sleep checklist</h2>
        <div class="content-list">
          <p>consistent sleep + wake time</p>
          <p>dim lights 60–90 min before bed</p>
          <p>limit screens late at night</p>
          <p>cool, dark room</p>
          <p>morning sunlight the next day</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">related</p>
          <span class="panel-stamp">next</span>
        </div>
        <h2>go deeper</h2>
        <div class="content-list">
          <p><a href="/how-to-fix-sleep">fix common sleep problems</a></p>
          <p><a href="/best-morning-routine">align your mornings</a></p>
          <p><a href="/start-here">follow the full baseline system</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">free guide</p>
          <span class="panel-stamp">system</span>
        </div>
        <h2>build your full daily baseline</h2>

        <form class="hero-actions" action="/start-here" method="GET">
          <input
            class="email-input"
            type="email"
            name="email"
            placeholder="your email"
            required
          />
          <button class="button primary-cta" type="submit">
            get the guide
          </button>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="two-panel-grid">
        <a href="/best-morning-routine" class="y2k-panel feature-card">
          <p class="panel-kicker">previous</p>
          <h3>morning routine</h3>
          <p>start your day with energy and rhythm.</p>
        </a>

        <a href="/how-to-fix-sleep" class="y2k-panel feature-card">
          <p class="panel-kicker">next</p>
          <h3>fix your sleep</h3>
          <p>reset your rhythm and solve common sleep issues.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
