---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="nervous system | human nature health"
  description="a simple guide to calming the nervous system and restoring balance."
>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">nervous system</p>
      <h1>your state of mind often begins in your nervous system.</h1>
      <p class="lead">
        stress, anxiety, tension, and burnout are not just mental. they are physical states
        in the body. learning to regulate them changes everything.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="content-block">
        <h2>why it matters</h2>
        <p>
          your nervous system controls how you feel, react, and experience life. when it is
          constantly activated, everything feels harder. when it is regulated, things feel
          clearer and more manageable.
        </p>
      </div>

      <div class="content-block">
        <h2>what goes wrong</h2>
        <p>
          constant stimulation, stress, lack of rest, poor sleep, and too much input keep
          the system in a heightened state. over time this becomes the baseline.
        </p>
      </div>

      <div class="content-block">
        <h2>core principles</h2>
        <div class="content-list">
          <p>slow down breathing</p>
          <p>reduce overstimulation</p>
          <p>spend time in calm environments</p>
          <p>move your body regularly</p>
          <p>create moments of stillness</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section accent-section">
    <div class="container narrow">
      <h2>simple regulation</h2>

      <div class="content-block">
        <h3>breath</h3>
        <p>
          slow breathing is one of the fastest ways to signal safety to the body.
        </p>
      </div>

      <div class="content-block">
        <h3>environment</h3>
        <p>
          reduce noise, chaos, and pressure. your surroundings directly affect your state.
        </p>
      </div>

      <div class="content-block">
        <h3>rhythm</h3>
        <p>
          consistent daily patterns help the nervous system feel stable instead of reactive.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="quote-block">
        <p>
          a calm system creates a clearer life.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="y2k-panel feature-card">
        <div class="panel-heading-row">
          <p class="panel-kicker">checklist</p>
          <span class="panel-stamp">calm</span>
        </div>
        <h2>simple nervous system checklist</h2>
        <div class="content-list">
          <p>slow breathing (5–10 min daily)</p>
          <p>reduce constant stimulation</p>
          <p>spend time in quiet environments</p>
          <p>get enough sleep consistently</p>
          <p>build calm daily routines</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="two-panel-grid">
        <a href="/movement" class="y2k-panel feature-card">
          <p class="panel-kicker">previous</p>
          <h3>movement</h3>
          <p>return to using the body and building strength.</p>
        </a>

        <a href="/food" class="y2k-panel feature-card">
          <p class="panel-kicker">next</p>
          <h3>food</h3>
          <p>continue into nourishment, energy, and diet.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>